# ──────────────────────────────────────────────────────────────────────────────
# DÉVELOPPEMENT LOCAL : cp .env.example .env  (puis ajuster si besoin)
# PRODUCTION          : remplir toutes les valeurs, ne jamais committer ce fichier
# ──────────────────────────────────────────────────────────────────────────────

# Domaine principal (prod uniquement)
# → admin accessible sur https://DOMAIN
# → app mobile accessible sur https://app.DOMAIN
DOMAIN=orderandpay.example.com

# Email pour Let's Encrypt (notifications d'expiration, prod uniquement)
EMAIL=admin@example.com

# Base de données
DB_USER=orderandpay
DB_PASSWORD=changeme_strong_password

# JWT — générer avec : openssl rand -base64 32
# En local le docker-compose utilise un fallback dev si cette variable est absente.
# En prod cette valeur est OBLIGATOIRE.
JWT_SECRET=changeme_generate_with_openssl_rand_base64_32

# Backup PostgreSQL
BACKUP_KEEP_DAYS=7   # rétention locale en jours

# Monitoring Grafana (optionnel — requis si docker-compose.monitoring.prod.yml est utilisé)
GRAFANA_PASSWORD=changeme_strong_password
COMPOSE_PROJECT=order-and-pay

# Upload S3 (optionnel — décommenter pour activer)
# S3_BUCKET=s3://mon-bucket/backups/orderandpay
# AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_ENDPOINT_URL=https://s3.fr-par.scw.cloud   # Scaleway ; vide pour AWS S3 natif
