<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ── Dev / défaut : console lisible ────────────────────────────────────── -->
  <springProfile name="!prod">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) [%X{requestId:-no-req}] - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.orderandpay" level="DEBUG"/>
  </springProfile>

  <!-- ── Prod : JSON structuré (lisible par Loki, Dozzle, Datadog…) ─────────── -->
  <springProfile name="prod">
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeCallerData>false</includeCallerData>
        <fieldNames>
          <timestamp>timestamp</timestamp>
          <message>message</message>
          <logger>logger</logger>
          <thread>thread</thread>
          <level>level</level>
          <levelValue>[ignore]</levelValue>
        </fieldNames>
        <!-- Champs MDC automatiquement inclus dans chaque entrée JSON -->
        <includeMdcKeyName>requestId</includeMdcKeyName>
        <includeMdcKeyName>restaurantId</includeMdcKeyName>
        <includeMdcKeyName>method</includeMdcKeyName>
        <includeMdcKeyName>path</includeMdcKeyName>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="JSON"/>
    </root>
    <logger name="com.orderandpay"              level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL"            level="WARN"/>
  </springProfile>

</configuration>
